# ============================================================
# 📁 ፋይል፦ EthAfri/.env.example
# 📝 ለውጥ፦ የአካባቢ ተለዋዋጮች ምሳሌ
# 📅 ቀን፦ 2026-06-20
# ============================================================

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=False
DATABASE_URL=postgresql://user:password@localhost:5432/ethafri

# AI API Keys
GEMINI_API_KEY=your-gemini-key-1
GEMINI_API_KEY_2=your-gemini-key-2
GEMINI_API_KEY_3=your-gemini-key-3
GROQ_API_KEY=your-groq-key
MISTRAL_API_KEY=your-mistral-key
OPENROUTER_API_KEY=your-openrouter-key
HUGGINGFACE_API_KEY=your-huggingface-key
GITHUB_TOKEN=your-github-token

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Render
RENDER_SERVICE_ID=your-render-service-id
RENDER_API_KEY=your-render-api-key

# Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ethafri.com
ADMIN_PASSWORD=your-secure-password

# Email (optional)
DEFAULT_FROM_EMAIL=noreply@ethafri.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Twilio (optional)
TWILIO_SID=your-twilio-sid
TWILIO_TOKEN=your-twilio-token
TWILIO_PHONE=+1234567890